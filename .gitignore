# --- Dependencies ---
frontend/node_modules/
backend/node_modules/

# --- Next.js build outputs ---
frontend/.next/
frontend/out/

# --- Backend build outputs (if using TS/Build) ---
backend/dist/
backend/build/

# --- Env files (never commit secrets) ---
**/.env
**/.env.local
**/.env.development
**/.env.production

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS / Editor files ---
.DS_Store
Thumbs.db

# --- SEO: never commit Google service-account keys ---
scripts/seo/*.json
!scripts/seo/package.json
!scripts/seo/package-lock.json
service-account*.json
*.gsc-key.json
gsc-*.json
